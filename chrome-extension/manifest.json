{
  "manifest_version": 3,
  "name": "Keepioo Naver Blog Auto Publish",
  "version": "1.1.1",
  "description": "keepioo blog 큐의 글을 사장님 네이버 블로그에 자동 발행 (KST 09:30 ~ 21:30, 각 시간 최대 3건).",

  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting",
    "debugger",
    "clipboardRead",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://*.naver.com/*",
    "https://www.keepioo.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Keepioo Naver Publisher"
  }
}
