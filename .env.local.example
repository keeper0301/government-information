# Site URL
NEXT_PUBLIC_SITE_URL=https://jungcheck.kr

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense (추후 설정)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (서버 전용 - 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (이메일 알림)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 텔레그램 운영 알림
TELEGRAM_BOT_TOKEN=1234567890:your-telegram-bot-token
TELEGRAM_CHAT_ID=123456789
# 여러 기기·계정으로 운영 알림을 받을 때 쉼표로 구분
TELEGRAM_OWNER_CHAT_IDS=123456789,987654321

# 공공데이터포털 API
DATA_GO_KR_API_KEY=your-data-go-kr-api-key
# 5/18 신규 — bokjiro Detail API kill-switch (3주째 사고 사장님 dashboard toggle).
# true 면 lib/detail-fetchers/bokjiro.ts 의 enabled() false → enrich cron 5/5 fail 알림 차단.
# data.go.kr endpoint 회복 확인 후 false (또는 미설정) 로 재개.
BOKJIRO_DETAIL_DISABLED=false

# Cron secret (cron 호출 보호용 비밀값)
CRON_SECRET=your-random-secret

# Keepio Agent 상시 운영 워커
# 로컬 실행: npm run agent:resident
# 설정 확인: npm run agent:resident:check
SITE_BASE_URL=https://www.keepioo.com
AGENT_RESIDENT_INTERVAL_MS=300000

# Keepio Agent health endpoint
# 로컬: http://127.0.0.1:8787/health
# 배포: Render/VPS 등 외부에서 접근 가능한 keepio-agent /health URL
KEEPIO_AGENT_HEALTH_URL=http://127.0.0.1:8787/health

# 어드민 권한 — /admin 페이지 접근 가능한 user_id 콤마 구분
# Supabase Auth → Users 에서 본인 user_id 확인 후 입력
# 예: ADMIN_USER_IDS=7e25d1c8-5ed5-4c54-bb1f-db2919a29cbd
ADMIN_USER_IDS=
