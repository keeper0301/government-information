# Site URL
NEXT_PUBLIC_SITE_URL=https://jungcheck.kr

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense (추후 설정)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (서버 전용 - 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (이메일 알림)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 공공데이터포털 API
DATA_GO_KR_API_KEY=your-data-go-kr-api-key

# Cron secret (for /api/collect endpoint protection)
CRON_SECRET=your-random-secret

# Keepio Agent sidecar health endpoint
# 로컬: http://127.0.0.1:8080/healthz
# 배포: Render/VPS 등 외부에서 접근 가능한 keepio-agent /healthz URL
KEEPIO_AGENT_HEALTH_URL=http://127.0.0.1:8080/healthz

# 어드민 권한 — /admin 페이지 접근 가능한 user_id 콤마 구분
# Supabase Auth → Users 에서 본인 user_id 확인 후 입력
# 예: ADMIN_USER_IDS=7e25d1c8-5ed5-4c54-bb1f-db2919a29cbd
ADMIN_USER_IDS=
