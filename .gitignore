# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# superpowers
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
data/
scripts/
.playwright-mcp/
*.png
!public/threads-og.png
supabase/.temp/
.gstack/

# Claude Code 개인 설정 (권한·환경변수 등, 커밋하지 않음)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# 임시 디버그 파일 (curl payload, dryRun 결과 등)
tmp/

# gstack 도구 메타데이터 (retros 등) — 로컬 전용
.context/
.design-audit/

# 로컬 lighthouse 측정 결과 (Phase 1 Core Web Vitals 검증용, 약 3MB JSON)
.lighthouse-results/
.lighthouse-results-baseline/

# Sentry CLI 토큰 캐시 (절대 커밋 금지)
.sentryclirc
